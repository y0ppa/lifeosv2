# Same Supabase project as apps/web. EXPO_PUBLIC_* vars are baked into the
# JS bundle at build time — that's expected for the anon key (see
# src/lib/supabase.ts). Never put the service_role key here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
